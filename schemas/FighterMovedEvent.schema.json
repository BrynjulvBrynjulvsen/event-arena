{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "io.practicegroup.arena.domain.FighterMovedEvent",
  "title": "FighterMovedEvent",
  "type": "object",
  "required": ["eventId", "eventType", "schemaVersion", "occurredAt", "matchId", "turn", "traceId", "payload"],
  "properties": {
    "eventType": { "const": "FighterMoved" },
    "payload": {
      "type": "object",
      "required": ["fighterId", "fromPosition", "toPosition"],
      "properties": {
        "fighterId": { "type": "string" },
        "fromPosition": {
          "type": "object",
          "required": ["x", "y"],
          "properties": {
            "x": { "type": "integer" },
            "y": { "type": "integer" }
          }
        },
        "toPosition": {
          "type": "object",
          "required": ["x", "y"],
          "properties": {
            "x": { "type": "integer" },
            "y": { "type": "integer" }
          }
        }
      }
    }
  }
}
